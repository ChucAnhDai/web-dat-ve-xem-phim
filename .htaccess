RewriteEngine On

# Send the project root to the front controller in /public
RewriteRule ^$ public/index.php [L]

# Route all non-file, non-directory requests to public/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
